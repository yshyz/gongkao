// 从课程名提取年份，用于排序
	function getYear(n) {
	  // 匹配 2027、2026 等四位年份
	  var m = n.match(/20\d{2}/);
	  if (m) return parseInt(m[0]);
	  // 匹配独立的 27、26 等两位年份（如"27陈怀安"）
	  m = n.match(/(?:^|[^\d])(2[7-9])(?:[^\d]|$)/);
	  if (m) return 2000 + parseInt(m[1]);
	  m = n.match(/(?:^|[^\d])(2[0-6])(?:[^\d]|$)/);
	  if (m) return 2000 + parseInt(m[1]);
	  return 0;
	}

	function renderCourses(filter) {
  const container = document.getElementById('content');
  container.innerHTML = '';

  const catsToShow = (filter === 'all') ? CATS : [filter];
  let total = 0;

  catsToShow.forEach(cat => {
    let courses = COURSES.filter(c => c.cat === cat);
    // 只在"全部"tab按年份降序排列（2027在前）
    if (filter === 'all') {
      courses = courses.slice().sort((a, b) => getYear(b.name) - getYear(a.name));
    }
    if (courses.length === 0) return;
    total += courses.length;

    const section = document.createElement('div');
    section.className = 'section';
    section.dataset.cat = cat;

    let html = '<div class="section-title">' + (CAT_ICONS[cat]||'') + ' ' + cat;
    html += '<span style="font-size:12px;color:var(--muted);font-weight:400;">（' + courses.length + '个）</span>';
    html += '</div>';

    courses.forEach((c, i) => {
      html += '<div class="course" data-cat="' + cat + '" data-keywords="' + c.name + '">';
      html += '<span class="course-num">' + String(i+1).padStart(2,'0') + '</span>';
      html += '<span class="course-name">' + c.name + '</span>';
      if (c.tag) {
        html += '<span class="course-tag tag-' + c.tag + '">' + (TAG_MAP[c.tag]||c.tag) + '</span>';
      }
      html += '<span class="course-links">';
      if (c.quark) html += '<a class="link-btn link-quark" href="' + c.quark + '" target="_blank">📥 夸克网盘</a>';
      html += '</span></div>';
    });

    section.innerHTML = html;
    container.appendChild(section);
  });

  document.getElementById('totalCount').textContent = total;
}

function filterCourses() {
  const kw = document.getElementById('search').value.toLowerCase().trim();
  if (!kw) {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelector('[data-cat="all"]').classList.add('active');
    renderCourses('all');
    return;
  }
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  renderCourses('all');
  // Hide non-matching courses
  let count = 0;
  document.querySelectorAll('.course').forEach(el => {
    const keywords = (el.dataset.keywords || '').toLowerCase();
    const cat = (el.dataset.cat || '').toLowerCase();
    if (keywords.includes(kw) || cat.includes(kw)) {
      el.style.display = '';
      count++;
    } else {
      el.style.display = 'none';
    }
  });
  // Hide empty sections
  document.querySelectorAll('.section').forEach(sec => {
    const visible = sec.querySelectorAll('.course[style*="display:"]').length;
    const total = sec.querySelectorAll('.course').length;
    if (visible === total) sec.style.display = 'none';
    else sec.style.display = '';
  });
  document.getElementById('totalCount').textContent = count;
}

