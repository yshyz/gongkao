  {cat:'公考名师',name:"2025年高照数量关系拿分稳稳班",quark:'https://pan.quark.cn/s/04fcd4df74b0'},
  {cat:'公考名师',name:"2025年龙飞百大图形推理解析精品班",quark:'https://pan.quark.cn/s/41c2e8a0cc4e'},
  {cat:'公考名师',name:"2025年王军涛常识公基（大盘基）系统精讲班",quark:'https://pan.quark.cn/s/fd5a15179777'},
  {cat:'公考名师',name:"2025年国考齐麟行测高分计划3班",quark:'https://pan.quark.cn/s/09e543b354ed'},
