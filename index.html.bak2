  {cat:'公考名师',name:"2025年江牧云申论精讲精练全家桶",quark:'https://pan.quark.cn/s/a1906a6aaded'},
  {cat:'公考名师',name:"2025年国考花生十三行测",quark:'https://pan.quark.cn/s/470157f5e378'},
  {cat:'公考名师',name:"2025年国考飞扬申论",quark:'https://pan.quark.cn/s/e31b5aec0400'},
  {cat:'公考名师',name:"2025年相丽君申论技巧趣学班",quark:'https://pan.quark.cn/s/7d0e7878bb5f'},
  {cat:'公考名师',name:"2025年国考明莉申论专项班",quark:'https://pan.quark.cn/s/87ea8d97f9c3'},
  {cat:'公考名师',name:"2025年鸿哥数量关系旗舰班",quark:'https://pan.quark.cn/s/fdb8351fdc6d'},
  {cat:'公考名师',name:"龙飞百大图形推理解析精品班",quark:'https://pan.quark.cn/s/41c2e8a0cc4e'},
];

// ============ RENDER ============
const CATS = ['押题模拟','国省考980','公考名师','事业单位','三支一扶','时政','公考面试','军队文职','公安专项','教招教资','历年真题','其他','赠送教辅'];
const CAT_ICONS = {押题模拟:'🎯',国省考980:'📦',公考名师:'👨‍🏫',事业单位:'🏛️',三支一扶:'🌾',时政:'📰',公考面试:'💬',军队文职:'🎖️',公安专项:'👮',教招教资:'📖',历年真题:'📝',其他:'📌',赠送教辅:'🎁'};
const TAG_MAP = {new:'最新',hot:'热门',free:'免费',update:'更新'};

// Set update date
document.getElementById('updateDate').textContent = new Date().toISOString().slice(0,10);

// Build tabs
CATS.forEach(cat => {
  const btn = document.createElement('button');
  btn.className = 'tab';
  btn.dataset.cat = cat;
  btn.textContent = (CAT_ICONS[cat]||'') + ' ' + cat;
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('search').value = '';
    renderCourses(cat);
  });
  document.getElementById('tabBar').appendChild(btn);
});

function renderCourses(filter) {
  const container = document.getElementById('content');
  container.innerHTML = '';

  const catsToShow = (filter === 'all') ? CATS : [filter];
  let total = 0;

  catsToShow.forEach(cat => {
    const courses = COURSES.filter(c => c.cat === cat);
    if (courses.length === 0) return;
    total += courses.length;

    const section = document.createElement('div');
    section.className = 'section';
    section.dataset.cat = cat;

    let html = '<div class="section-title">' + (CAT_ICONS[cat]||'') + ' ' + cat;
    html += '<span style="font-size:12px;color:var(--muted);font-weight:400;">（' + courses.length + '个）</span>';
    html += '</div>';

    courses.forEach((c, i) => {
      html += '<div class="course" data-cat="' + cat + '" data-keywords="' + c.name + '">';
      html += '<span class="course-num">' + String(i+1).padStart(2,'0') + '</span>';
      html += '<span class="course-name">' + c.name + '</span>';
      if (c.tag) {
        html += '<span class="course-tag tag-' + c.tag + '">' + (TAG_MAP[c.tag]||c.tag) + '</span>';
      }
      html += '<span class="course-links">';
      if (c.quark) html += '<a class="link-btn link-quark" href="' + c.quark + '" target="_blank" onclick="trackClick(\'' + cat + '\',\'quark\')">📥 夸克网盘</a>';
      if (false && c.baidu) html += '<a class="link-btn link-baidu" href="' + c.baidu + '" target="_blank" onclick="trackClick(\'' + cat + '\',\'baidu\')">📦 百度网盘</a>';
      html += '</span></div>';
    });

    section.innerHTML = html;
    container.appendChild(section);
  });

  document.getElementById('totalCount').textContent = total;
}

function filterCourses() {
  const kw = document.getElementById('search').value.toLowerCase().trim();
  if (!kw) {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelector('[data-cat="all"]').classList.add('active');
    renderCourses('all');
    return;
  }
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  renderCourses('all');
  // Hide non-matching courses
  let count = 0;
  document.querySelectorAll('.course').forEach(el => {
    const keywords = (el.dataset.keywords || '').toLowerCase();
    const cat = (el.dataset.cat || '').toLowerCase();
    if (keywords.includes(kw) || cat.includes(kw)) {
      el.style.display = '';
      count++;
    } else {
      el.style.display = 'none';
    }
  });
  // Hide empty sections
  document.querySelectorAll('.section').forEach(sec => {
    const visible = sec.querySelectorAll('.course[style*="display:"]').length;
    const total = sec.querySelectorAll('.course').length;
    if (visible === total) sec.style.display = 'none';
    else sec.style.display = '';
  });
  document.getElementById('totalCount').textContent = count;
}

function trackClick(cat, type) {
  console.log('点击：' + cat + ' | ' + type);
  // 这里以后可以接入统计
}

// Init
renderCourses('all');
</script>
</body>
</html>
