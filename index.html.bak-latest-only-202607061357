<style>
:root {
  --bg: #f5f6fa;
  --card: #fff;
  --text: #1a1a2e;
  --muted: #6b7280;
  --accent: #e74c3c;
  --blue: #2980b9;
  --green: #27ae60;
  --border: #e5e7eb;
}
* { margin:0; padding:0; box-sizing:border-box; }
body { background:var(--bg); color:var(--text); font-family:-apple-system,"Microsoft YaHei",sans-serif; line-height:1.6; }
.container { max-width:900px; margin:0 auto; padding:16px; }

/* Header */
.header { background:linear-gradient(135deg,#1a1a2e,#16213e); color:#fff; text-align:center; padding:32px 20px; border-radius:16px; margin-bottom:16px; }
.header h1 { font-size:30px; margin-bottom:6px; letter-spacing:2px; }
.header .sub { font-size:13px; opacity:0.7; }
.header .badge { display:inline-block; background:var(--accent); padding:4px 14px; border-radius:20px; font-size:12px; font-weight:700; margin-top:8px; animation:pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.6} }

/* Search + Stats */
.top-bar { display:flex; gap:10px; margin-bottom:14px; flex-wrap:wrap; }
.search-box { flex:1; min-width:200px; padding:10px 14px; border:2px solid var(--border); border-radius:10px; font-size:14px; outline:none; transition:.2s; background:var(--card); }
.search-box:focus { border-color:var(--accent); }
.stat { display:flex; align-items:center; gap:4px; padding:8px 14px; background:var(--card); border-radius:10px; font-size:12px; color:var(--muted); border:1px solid var(--border); }
.stat b { color:var(--accent); }
.maintenance-notice { background:linear-gradient(135deg,#fff7ed,#fee2e2); border:1px solid #fed7aa; border-left:5px solid var(--accent); border-radius:12px; padding:14px 16px; margin-bottom:14px; color:#7c2d12; }
.maintenance-notice strong { display:block; font-size:15px; margin-bottom:3px; color:#c2410c; }
.maintenance-notice span { font-size:13px; color:#9a3412; }

/* Tabs */
.tabs { display:flex; gap:6px; margin-bottom:14px; overflow-x:auto; padding-bottom:4px; }
.tab { padding:8px 14px; border-radius:20px; font-size:13px; font-weight:600; white-space:nowrap; cursor:pointer; border:1px solid var(--border); background:var(--card); color:var(--muted); transition:.2s; }
.tab.active { background:var(--accent); color:#fff; border-color:var(--accent); }
.tab:hover:not(.active) { border-color:#9ca3af; }

/* Section */
.section { background:var(--card); border-radius:12px; padding:18px; margin-bottom:12px; border:1px solid var(--border); }
.section-title { font-size:16px; font-weight:700; margin-bottom:4px; display:flex; align-items:center; gap:6px; }
.section-sub { font-size:12px; color:var(--muted); margin-bottom:12px; }

/* Course Item */
.course { display:flex; align-items:center; padding:10px 12px; border-bottom:1px solid #f3f4f6; gap:10px; transition:.2s; border-radius:6px; flex-wrap:wrap; }
.course:hover { background:#f9fafb; }
.course:last-child { border-bottom:none; }
.course-num { font-size:11px; color:var(--muted); min-width:36px; }
.course-name { flex:1; min-width:180px; font-size:14px; font-weight:500; }
.course-tag { font-size:10px; padding:2px 8px; border-radius:10px; font-weight:600; white-space:nowrap; }
.tag-new { background:#fee2e2; color:#dc2626; }
.tag-hot { background:#fef3c7; color:#d97706; }
.tag-free { background:#d1fae5; color:#059669; }
.tag-update { background:#dbeafe; color:#2563eb; }

.course-links { display:flex; gap:6px; flex-wrap:wrap; }
.link-btn { display:inline-block; padding:4px 12px; border-radius:6px; font-size:12px; font-weight:600; text-decoration:none; transition:.2s; white-space:nowrap; }
.link-quark { background:#fff7ed; color:#ea580c; border:1px solid #fed7aa; }
.link-quark:hover { background:#fed7aa; }

/* Footer */
.footer { text-align:center; padding:20px; margin-top:8px; }
.footer .cta { display:inline-block; background:var(--accent); color:#fff; padding:10px 28px; border-radius:24px; font-weight:700; text-decoration:none; margin:8px; font-size:14px; }
.footer .tip { color:var(--muted); font-size:12px; margin-top:10px; }

/* Collapse */
.collapse-btn { cursor:pointer; color:var(--blue); font-size:12px; float:right; }
.collapse-btn:hover { text-decoration:underline; }

.hidden { display:none; }
.empty-msg { text-align:center; color:var(--muted); padding:30px; font-size:14px; }

/* 侧边联系栏 */
.side-contact { position:fixed; right:16px; top:50%; transform:translateY(-50%); z-index:999; width:160px; background:var(--card); border-radius:16px; box-shadow:0 8px 30px rgba(0,0,0,0.15); padding:18px 14px; text-align:center; border:2px solid #fee2e2; }
.side-contact .sc-title { font-size:13px; font-weight:700; color:#dc2626; margin-bottom:6px; }
.side-contact .sc-desc { font-size:11px; color:var(--muted); margin-bottom:12px; line-height:1.5; }
.side-contact .sc-btn { display:block; background:linear-gradient(135deg,#e74c3c,#f97316); color:#fff; padding:8px 0; border-radius:20px; font-size:12px; font-weight:700; text-decoration:none; margin-bottom:6px; cursor:pointer; border:none; width:100%; }
.side-contact .sc-btn:hover { opacity:0.9; }
.side-contact .sc-tip { font-size:10px; color:var(--muted); }

@media (max-width:768px) {
  .side-contact { display:none; }
  .mobile-contact { display:flex !important; }
}
.mobile-contact { display:none; position:fixed; bottom:0; left:0; right:0; z-index:999; background:linear-gradient(90deg,#fef3c7,#fee2e2); padding:10px 16px; align-items:center; justify-content:center; gap:10px; border-top:2px solid #fca5a5; }
.mobile-contact .sc-btn { background:linear-gradient(135deg,#e74c3c,#f97316); color:#fff; padding:8px 18px; border-radius:20px; font-size:13px; font-weight:700; text-decoration:none; border:none; cursor:pointer; }
.mobile-contact span { font-size:12px; color:#dc2626; font-weight:600; }

@media (max-width:500px) {
  .course { flex-direction:column; align-items:flex-start; gap:6px; }
  .course-links { justify-content:flex-start; }
  .course-name { font-size:13px; }
}
</style>
